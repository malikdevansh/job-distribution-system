{
  "name": "jobqueue-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "start:api": "npm --workspace=@jobqueue/backend-api run start",
    "start:worker": "npm --workspace=@jobqueue/worker-service run start",
    "start:scheduler": "npm --workspace=@jobqueue/scheduler-service run start",
    "start:frontend": "npm --workspace=@jobqueue/frontend run dev"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "ws": "^8.21.0"
  }
}
